# База данных PostgreSQL (локальная)
# Замените user и password на ваши учетные данные
# Пример: postgresql://postgres:myPassword@localhost:5432/tourist_agency?schema=public
DATABASE_URL="postgresql://user:password@localhost:5432/tourist_agency?schema=public"

# URL API для клиента (Next.js)
NEXT_PUBLIC_API_URL="http://localhost:3000"
